        axes,
        [sim_e1, sim_e2],
        [exp_e1, exp_e2],
        ["E1 (keV)", "E2 (keV)"],
        ["(a) first layer", "(b) second layer"],
    ):
        sim_c, _ = np.histogram(sim_e, bins=exp_e)
        exp_h = smooth_hist(normalize_hist(exp_c, exp_e))
        sim_h = smooth_hist(normalize_hist(sim_c, exp_e))
        centers = 0.5 * (exp_e[:-1] + exp_e[1:])
        ax.plot(centers, exp_h, color="tab:red", linewidth=1.1, label="Experimental")
