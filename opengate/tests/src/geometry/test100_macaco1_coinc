def prepare_layered_singles(scatter_df: pd.DataFrame, absorber_df: pd.DataFrame) -> pd.DataFrame:
    sc = scatter_df.copy()
    ab = absorber_df.copy()
    sc["PreStepUniqueVolumeID"] = "scatterer"
    ab["PreStepUniqueVolumeID"] = "absorber"
    return pd.concat([sc, ab], ignore_index=True)


def build_singles_dataframe(layered: pd.DataFrame) -> pd.DataFrame:
    required = [
        "EventID", "GlobalTime", "PreStepUniqueVolumeID",
        "TotalEnergyDeposit", "PostPosition_X", "PostPosition_Y", "PostPosition_Z",
    ]
    missing = [c for c in required if c not in layered.columns]
    if missing:
        raise ValueError(f"Missing required singles columns: {missing}")
    return layered[required]


def extract_sorted_coincidences(
    coincidences: pd.DataFrame,
) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
    is_scatt1 = coincidences["PreStepUniqueVolumeID1"].astype(str).str.lower().str.contains("scatt")
    flag = is_scatt1.to_numpy()

    def _pick(col_a, col_b):
        return np.where(flag, coincidences[col_a], coincidences[col_b]).astype(float)

    scatt_pos = np.column_stack([_pick(f"PostPosition_{ax}1", f"PostPosition_{ax}2") for ax in "XYZ"])
    abs_pos   = np.column_stack([_pick(f"PostPosition_{ax}2", f"PostPosition_{ax}1") for ax in "XYZ"])
    e_scatt = _pick("TotalEnergyDeposit1", "TotalEnergyDeposit2")
    e_abs   = _pick("TotalEnergyDeposit2", "TotalEnergyDeposit1")
    return scatt_pos, abs_pos, e_scatt, e_abs, flag


def pairs_from_coincident_singles(df: pd.DataFrame) -> pd.DataFrame:
    rows = []
    for _, group in df.groupby("CoincID"):
        if len(group) < 2:
            continue
        s1, s2 = group.iloc[0], group.iloc[1]
        rows.append({
            "PreStepUniqueVolumeID1": s1["PreStepUniqueVolumeID"],
            "PreStepUniqueVolumeID2": s2["PreStepUniqueVolumeID"],
            **{f"PostPosition_{ax}1": s1[f"PostPosition_{ax}"] for ax in "XYZ"},
            **{f"PostPosition_{ax}2": s2[f"PostPosition_{ax}"] for ax in "XYZ"},
            "TotalEnergyDeposit1": s1["TotalEnergyDeposit"],
            "TotalEnergyDeposit2": s2["TotalEnergyDeposit"],
        })
    return pd.DataFrame(rows)


