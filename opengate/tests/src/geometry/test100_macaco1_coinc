def plot_esum_overlay(
    sim_esum: np.ndarray, exp_counts: np.ndarray, exp_edges: np.ndarray, out_dir: Path
) -> None:
    centers = 0.5 * (exp_edges[:-1] + exp_edges[1:])
    sim_counts, _ = np.histogram(sim_esum, bins=exp_edges)
    exp_norm = smooth_hist(normalize_hist(exp_counts, exp_edges))
    sim_norm = smooth_hist(normalize_hist(sim_counts, exp_edges))

    matplotlib.use("Agg")
    fig, ax = plt.subplots(figsize=(7.0, 5.0))
    ax.step(centers, exp_norm, where="mid", color="tab:red", label="Experimental")
    ax.step(centers, sim_norm, where="mid", color="black", linestyle="--", label="Simulated")
    ax.set_xlabel("E_sum (keV)")
    ax.set_ylabel("Area-normalised counts")
    ax.set_xlim(0, exp_edges[-1])
    ax.set_ylim(bottom=0)
    ax.grid(True, linestyle="--", alpha=0.2)
    ax.legend(frameon=False)
    fig.tight_layout()
    out_path = out_dir / "esum_overlay.png"
    fig.savefig(out_path, dpi=200)
    plt.close(fig)
    print(f"Saved E_sum overlay: {out_path}")


def plot_e1e2_overlay(
    sim_e1: np.ndarray,
    sim_e2: np.ndarray,
    exp_e1: tuple[np.ndarray, np.ndarray],
    exp_e2: tuple[np.ndarray, np.ndarray],
    out_dir: Path,
) -> None:
    matplotlib.use("Agg")
    fig, axes = plt.subplots(1, 2, figsize=(9.5, 4.0), sharey=True)
