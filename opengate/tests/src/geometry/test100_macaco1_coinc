def _open_root_tree(path: Path, *, retries: int = 5, delay_s: float = 0.5):
    for _ in range(retries):
        if not path.exists():
            time.sleep(delay_s)
            continue
        with uproot.open(str(path)) as f:
            keys = list(f.keys())
            if keys:
                return f[keys[0].split(";")[0]]
        time.sleep(delay_s)
    raise RuntimeError(f"ROOT file has no trees after {retries} attempts: {path}")


def load_root_as_dataframe(path: Path, out_dir: Path) -> pd.DataFrame:
    resolved = path if path.exists() else out_dir / path.name
    return _open_root_tree(resolved).arrays(library="pd")


def load_digitizer_singles(
    scatt_file: Path, abs_file: Path, out_dir: Path
) -> tuple[pd.DataFrame, pd.DataFrame]:
    return (
        load_root_as_dataframe(scatt_file, out_dir),
        load_root_as_dataframe(abs_file, out_dir),
    )


def load_experimental_esum_hist(path: Path) -> tuple[np.ndarray, np.ndarray]:
    path = Path(path)
    if path.suffix.lower() == ".root":
        with uproot.open(path) as f:
            key = next((k for k in ("EsumReal", "hSpecSum_coincidences") if k in f), None)
            if key is None:
                raise ValueError(f"No Esum histogram found in {path}")
            counts, edges = f[key].to_numpy()
        return np.asarray(counts, dtype=float), np.asarray(edges, dtype=float)
    data = np.loadtxt(path)
    if data.ndim == 1:
        data = data.reshape(1, -1)
    e_sum = data[:, 5] + data[:, 10]
    bins = np.arange(0.0, ESUM_MAX_KEV + ESUM_BIN_WIDTH_KEV, ESUM_BIN_WIDTH_KEV)
    counts, edges = np.histogram(e_sum[e_sum > 0], bins=bins)
    return counts.astype(float), edges.astype(float)


def load_experimental_e1e2_hist(
    path: Path,
) -> tuple[tuple[np.ndarray, np.ndarray], tuple[np.ndarray, np.ndarray]]:
    path = Path(path)
    if path.suffix.lower() == ".root":
        with uproot.open(path) as f:
            e1_key = next((k for k in ("E1CoincReal", "hSpec11_coincidences") if k in f), None)
            e2_key = next((k for k in ("E2CoincReal", "hSpec21_coincidences") if k in f), None)
            if e1_key is None or e2_key is None:
                raise ValueError(f"No E1/E2 histograms found in {path}")
            e1_counts, e1_edges = f[e1_key].to_numpy()
            e2_counts, e2_edges = f[e2_key].to_numpy()
        return (
            (np.asarray(e1_counts, dtype=float), np.asarray(e1_edges, dtype=float)),
            (np.asarray(e2_counts, dtype=float), np.asarray(e2_edges, dtype=float)),
        )
    data = np.loadtxt(path)
    if data.ndim == 1:
        data = data.reshape(1, -1)
    bins = np.arange(0.0, E_MAX_KEV + E_BIN_WIDTH_KEV, E_BIN_WIDTH_KEV)
    e1_counts, e1_edges = np.histogram(data[data[:, 5] > 0, 5], bins=bins)
    e2_counts, e2_edges = np.histogram(data[data[:, 10] > 0, 10], bins=bins)
    return (e1_counts.astype(float), e1_edges.astype(float)), (e2_counts.astype(float), e2_edges.astype(float))


def load_experimental_arm_histograms(path: Path) -> dict[str, tuple[np.ndarray, np.ndarray]]:
    mapping = {
        "all": "AngularUncertaintyReal",
        "511": "AngularUncertaintyReal511",
        "1275": "AngularUncertaintyReal1275",
    }
    histograms = {}
    with uproot.open(path) as f:
        for key, name in mapping.items():
            if name not in f:
                continue
            counts, edges = f[name].to_numpy()
            histograms[key] = (
                0.5 * (edges[:-1] + edges[1:]).astype(float),
                np.asarray(counts, dtype=float),
            )
    if not histograms:
        raise ValueError(f"No AngularUncertainty* histograms found in {path}")
    return histograms


def write_singles_root(path: Path, df: pd.DataFrame) -> Path:
    df = df.copy()
    for col in df.columns:
        if df[col].dtype == object:
            df[col] = pd.Categorical(df[col])
    data = root_tree_get_branch_data(df.to_dict(orient="list"))
    with uproot.recreate(path) as f:
        root_write_tree(f, "Singles", root_tree_get_branch_types(data), data)
    return path


