def compute_theta_c(e_scatt: np.ndarray, e0: np.ndarray) -> np.ndarray:
    e_scattered = e0 - e_scatt
    valid = (e0 > 0.0) & (e_scattered > 0.0)
    cos_theta = np.full_like(e0, np.nan, dtype=float)
    cos_theta[valid] = 1.0 - ME_C2_KEV * e_scatt[valid] / (e_scattered[valid] * e0[valid])
    cos_theta = np.where((cos_theta >= -1.0) & (cos_theta <= 1.0), cos_theta, np.nan)
    return np.arccos(cos_theta)


def compute_theta_g(
    scatter_pos: np.ndarray, absorber_pos: np.ndarray, source_pos: np.ndarray
) -> np.ndarray:
    incoming = scatter_pos - source_pos
    outgoing = absorber_pos - scatter_pos
    n_in  = np.linalg.norm(incoming, axis=1)
    n_out = np.linalg.norm(outgoing, axis=1)
    valid = (n_in > 0.0) & (n_out > 0.0)
    cos_theta = np.full(n_in.shape, np.nan, dtype=float)
    dot = np.einsum("ij,ij->i", incoming, outgoing)
    cos_theta[valid] = dot[valid] / (n_in[valid] * n_out[valid])
    cos_theta = np.where((cos_theta >= -1.0) & (cos_theta <= 1.0), cos_theta, np.nan)
    return np.arccos(cos_theta)


def compute_arm(
    scatter_pos: np.ndarray,
    absorber_pos: np.ndarray,
    e_scatt: np.ndarray,
    e_abs: np.ndarray,
    source_pos: np.ndarray,
) -> np.ndarray:
    e0 = np.where(e_scatt + e_abs < 600.0, 511.0, 1275.0)
    theta_c = compute_theta_c(e_scatt, e0)
    theta_g = compute_theta_g(scatter_pos, absorber_pos, source_pos)
    valid = ~np.isnan(theta_c) & ~np.isnan(theta_g)
    return (theta_g - theta_c)[valid]


# ---------------------------------------------------------------------------
# Histogram utilities
# ---------------------------------------------------------------------------

def normalize_hist(counts: np.ndarray, edges: np.ndarray) -> np.ndarray:
    total = float(np.sum(counts))
    if total <= 0:
        return np.zeros_like(counts, dtype=float)
    return counts.astype(float) / (total * float(np.diff(edges)[0]))


def smooth_hist(counts: np.ndarray, sigma_bins: float = 1.2) -> np.ndarray:
    if counts.size == 0 or sigma_bins <= 0:
        return counts
    half = int(np.ceil(3.0 * sigma_bins))
    x = np.arange(-half, half + 1, dtype=float)
    kernel = np.exp(-0.5 * (x / sigma_bins) ** 2)
    kernel /= kernel.sum()
    return np.convolve(counts, kernel, mode="same")


def rebin_hist(counts: np.ndarray, edges: np.ndarray, factor: int) -> tuple[np.ndarray, np.ndarray]:
    if factor <= 1:
        return counts, edges
    n = (len(counts) // factor) * factor
    if n == 0:
        return counts, edges
    return counts[:n].reshape(-1, factor).sum(axis=1), edges[:n + 1:factor]


# ---------------------------------------------------------------------------
# Fitting
# ---------------------------------------------------------------------------

def lorentzian(x, amp, x0, gamma, offset):
    hg = 0.5 * gamma
    return amp * hg**2 / ((x - x0)**2 + hg**2) + offset


def fit_lorentzian(x: np.ndarray, y: np.ndarray) -> tuple[np.ndarray | None, np.ndarray | None]:
    if curve_fit is None or np.count_nonzero(y) < 5:
        return None, None
    amp0 = float(np.max(y))
    x0 = float(x[np.argmax(y)])
    above_half = x[y >= amp0 / 2.0]
    gamma0 = float(above_half[-1] - above_half[0]) if len(above_half) >= 2 else float((x[-1] - x[0]) / 10.0)
    gamma0 = max(gamma0, float(np.diff(x).mean()))
    try:
        popt, pcov = curve_fit(
            lorentzian, x, y,
            p0=[amp0, x0, gamma0, float(np.min(y))],
            bounds=([0, x.min(), np.diff(x).mean(), -np.inf], [amp0, x.max(), np.ptp(x), np.inf]),
            maxfev=10000,
        )
    except RuntimeError:
        return None, None
    return popt, pcov


