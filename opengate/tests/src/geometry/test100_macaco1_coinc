        ax.set_xlabel(xlabel)
        ax.set_ylabel("Normalised counts")
        ax.set_ylim(bottom=0)
        ax.grid(True, linestyle="--", alpha=0.2)
        ax.legend(frameon=False)
        ax.text(0.5, -0.22, caption, transform=ax.transAxes, ha="center", va="top")
