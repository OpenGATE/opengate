def build_simulation(seed: int, threads: int, out_dir: Path) -> tuple[gate.Simulation, Path, Path]:
    mm  = g4_units.mm
    Bq  = g4_units.Bq
    sec = g4_units.s

    sim = gate.Simulation()
    sim.visu = False
    sim.number_of_threads = threads
    sim.check_volumes_overlap = False
    sim.random_seed = seed

    cam = add_macaco1_camera(sim, camera_translation=(0.0, 0.0, 8.3))
    scatterer = cam["scatterer"]
    absorber  = cam["absorber"]

    src_holder = sim.add_volume("Sphere", "source_holder")
    src_holder.mother = sim.world
    src_holder.material = "Plastic"
    src_holder.rmax = 0.25 * mm

    src = sim.add_source("GenericSource", "Na22_decay")
    src.particle = "ion 11 22"
    src.attached_to = src_holder
    src.activity = (847e3 / threads) * Bq
    src.position.type = "point"
    src.direction.type = "iso"
    src.user_particle_life_time = 0

    sim.physics_manager.enable_decay = True
    sim.run_timing_intervals = [[0, 7 * sec]]

    scatt_file, abs_file = add_macaco1_camera_digitizer(sim, scatterer, absorber, out_dir)
    return sim, scatt_file, abs_file


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> dict:
    parser = argparse.ArgumentParser(description="MACACO1 coincidence ARM validation")
    parser.add_argument("--seed", type=int, default=None)
    parser.add_argument("--threads", type=int, default=3)
    parser.add_argument("--dump-determinism", action="store_true")
    parser.add_argument("--determinism-tag", default="run1")
    args, _ = parser.parse_known_args()

    seed = args.seed if args.seed is not None else random.randint(1, 2**31 - 1)
    keV = g4_units.keV
    out_dir = paths.output

    sim, scatt_file, abs_file = build_simulation(seed, args.threads, out_dir)
    sim.run()

    scatt_df, abs_df = load_digitizer_singles(scatt_file, abs_file, out_dir)
    assert not scatt_df.empty, "No scatterer singles produced"
    assert not abs_df.empty,   "No absorber singles produced"
    print("✓ Scatterer singles present")
    print("✓ Absorber singles present")

    layered = prepare_layered_singles(scatt_df, abs_df)
    singles_path = write_singles_root(out_dir / "singles_sim.root", build_singles_dataframe(layered))

    time_window = COINC_TIME_WINDOW_NS * g4_units.ns
    with uproot.open(singles_path) as f:
        sim_tree = f["Singles"]
        coinc_singles = cc_coincidences_sorter(sim_tree, time_window)

    if coinc_singles is None or coinc_singles.empty:
        raise AssertionError("No coincidences after sorter")

    coinc_singles = kill_multiple_coinc(coinc_singles, group_col="CoincID")
    coinc_singles = kill_same_volume_pairs(coinc_singles, group_col="CoincID", volume_col="PreStepUniqueVolumeID")

    if coinc_singles.empty:
        raise AssertionError("No coincidences remain after filtering")

    coinc_pairs = pairs_from_coincident_singles(coinc_singles)
    assert not coinc_pairs.empty, "No coincidence pairs after rebuild"

    scatt_pos, abs_pos, e_scatt, e_abs, _ = extract_sorted_coincidences(coinc_pairs)
    e_scatt /= keV
    e_abs   /= keV
    e_sum = e_scatt + e_abs
    mask_1275 = e_sum >= 600.0

    exp_counts, exp_edges = load_experimental_esum_hist(EXP_COINC_FILE)
    plot_esum_overlay(e_sum, exp_counts, exp_edges, out_dir)
    plot_e1e2_overlay(e_scatt, e_abs, *load_experimental_e1e2_hist(EXP_E1E2_FILE), out_dir)

    sim_mu, sim_fwhm, passed = None, None, False

    print(
        "\n[ARM validation] NOTE: the FWHM pass/fail criterion has a ±30% tolerance.\n"
        "  Run-to-run variance analysis showed simulated FWHM fluctuates ~10–25%\n"
        "  depending on seed and statistics. A single short run may fail due to\n"
        "  statistical fluctuations alone — re-run with a different seed or longer\n"
        "  duration before concluding there is a physics problem.\n"
        f"  Pass threshold: ±{FWHM_PASS_THRESHOLD_PCT:.0f}% of experimental FWHM."
    )

    if EXP_COINC_ROOT.exists():
        exp_arm_hists = load_experimental_arm_histograms(EXP_COINC_ROOT)
        sim_arm = compute_arm(
            scatt_pos[mask_1275], abs_pos[mask_1275],
            e_scatt[mask_1275], e_abs[mask_1275],
            SOURCE_POS_MM,
        )
        centers, counts = exp_arm_hists["1275"]
        fit_stats = plot_arm_overlay("1275", centers, counts, sim_arm, out_dir, sim_bin_factor=2)

        if fit_stats is None:
            print("✗ ARM plot failed")
        else:
            _, _, sim_mu, sim_fwhm, exp_fwhm = fit_stats
            if sim_fwhm is not None and exp_fwhm is not None:
                diff_pct = abs(sim_fwhm - exp_fwhm) / exp_fwhm * 100.0
                print(
                    f"1275 FWHM: sim={sim_fwhm:.3f} {ARM_UNITS}, "
                    f"exp={exp_fwhm:.3f} {ARM_UNITS}, diff={diff_pct:.1f}% "
                    f"(threshold={FWHM_PASS_THRESHOLD_PCT:.1f}%)"
                )
                passed = diff_pct < FWHM_PASS_THRESHOLD_PCT
                print(f"{'✓' if passed else '✗'} 1275 FWHM {'within' if passed else 'exceeds'} tolerance")
            else:
                print("ARM FWHM fit unavailable — FAIL")
    else:
        print("Experimental ROOT file not found; skipping ARM validation.")

    if args.dump_determinism:
        tag = args.determinism_tag
        for name, arr in [("e_sum", e_sum), ("arm", sim_arm if EXP_COINC_ROOT.exists() else np.array([]))]:
            path = out_dir / f"determinism_{name}_{tag}.npy"
            if path.exists():
                ref = np.load(path)
                match = ref.shape == arr.shape
                print(f"[determinism] {name} same shape: {match}")
                if match:
                    print(f"[determinism] {name} max abs diff: {np.max(np.abs(ref - arr)):.6g}")
            else:
                np.save(path, arr)
                print(f"[determinism] Saved baseline: {path.name}")

    print("\n✓ MACACO1 ARM validation complete")

    result = {"seed": seed, "sim_mu": sim_mu, "sim_fwhm": sim_fwhm, "passed": passed}
    result_path = paths.output / "runner_result.json"
    with open(result_path, "w") as f:
        json.dump(result, f)

    return result


if __name__ == "__main__":
    main()
